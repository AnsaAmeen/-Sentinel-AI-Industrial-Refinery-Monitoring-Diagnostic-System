        "jsCode": "const data = $input.first().json;\n\n// 1. Sensors Data Verification\nconst temp = data.temperature || \"0\";\nconst pressure = data.pressure || \"36\"; \nconst vibration = data.vibration || \"11.1\"; \nconst reportDate = data.formattedDate || new Date().toLocaleString();\n\n// 2. AI Analysis Parameter Verification\nconst aiAdvice = data.content?.parts?.[0]?.text || \"No AI advice available.\";\n\n// 3. Generating the Visual HTML Body\nconst htmlBody = `\n<div style=\"font-family: Arial, sans-serif; max-width: 500px; border: 1px solid #ccc; padding: 20px; border-radius: 10px; background-color: #ffffff;\">\n  <h2 style=\"color: #d9534f; text-align: center;\">Industrial Status Report</h2>\n  <p style=\"text-align: center;\"><strong>Date:</strong> ${reportDate}</p>\n  \n  <table style=\"width: 100%; border-collapse: collapse; margin-top: 10px;\">\n    <tr style=\"background-color: #f2f2f2;\">\n      <th style=\"border: 1px solid #ddd; padding: 10px; text-align: left;\">Parameter</th>\n      <th style=\"border: 1px solid #ddd; padding: 10px; text-align: left;\">Live Value</th>\n    </tr>\n    <tr>\n      <td style=\"border: 1px solid #ddd; padding: 10px;\">Temperature</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px; color: red;\"><b>${temp}°C</b></td>\n    </tr>\n    <tr>\n      <td style=\"border: 1px solid #ddd; padding: 10px;\">Pressure</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px;\">${pressure} psi</td>\n    </tr>\n    <tr>\n      <td style=\"border: 1px solid #ddd; padding: 10px;\">Vibration</td>\n      <td style=\"border: 1px solid #ddd; padding: 10px;\">${vibration} mm/s</td>\n    </tr>\n  </table>\n\n  <div style=\"margin-top: 20px; padding: 15px; background-color: #fff3f3; border-left: 5px solid #d9534f;\">\n    <strong style=\"color: #d9534f;\">🤖 AI Diagnostic Analysis:</strong><br>\n    <p style=\"margin-top: 5px; font-style: italic; line-height: 1.5; color: #333;\">${aiAdvice}</p>\n  </div>\n  <div style=\"font-size: 10px; color: #999; text-align: center; margin-top: 10px;\">Generated automatically by n8n Industrial Bot</div>\n</div>\n`;\n\n// 4. Return both JSON and the actual Binary File\n// ... baaki saara logic wahi rehne dein ...\n\nreturn {\n  json: {\n    html_report: htmlBody, // Ye hamara visual table hai\n    subject_date: reportDate\n  }\n};"
      },
